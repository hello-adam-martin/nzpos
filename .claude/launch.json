{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["node_modules/.bin/next", "dev"],
      "env": { "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin" },
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "Supabase Local",
      "runtimeExecutable": "supabase",
      "runtimeArgs": ["start"],
      "port": 54321,
      "autoPort": false
    }
  ]
}
