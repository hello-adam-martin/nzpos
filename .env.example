# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Store ID (legacy — single-store v1 references)
STORE_ID=your_store_uuid_here
NEXT_PUBLIC_STORE_ID=your_store_uuid_here

# Application URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=lvh.me:3000

# Multi-tenant routing
ROOT_DOMAIN=lvh.me:3000

# Staff PIN JWT
STAFF_JWT_SECRET=your_staff_jwt_secret_here

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Billing (Phase 15 — SaaS subscription webhooks)
STRIPE_BILLING_WEBHOOK_SECRET=whsec_your_billing_webhook_secret

# Stripe Billing Price IDs (Phase 15 — per-add-on subscriptions)
STRIPE_PRICE_XERO=price_your_xero_addon_price_id
STRIPE_PRICE_EMAIL_NOTIFICATIONS=price_your_email_addon_price_id
STRIPE_PRICE_CUSTOM_DOMAIN=price_your_custom_domain_price_id

# Email (Phase 9 — transactional email via Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_ADDRESS=noreply@yourdomain.com

# Xero Integration (Phase 6 — accounting sync)
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
XERO_REDIRECT_URI=http://localhost:3000/api/xero/callback

# Cron Authentication (for scheduled jobs)
CRON_SECRET=your_cron_secret_here

# Notifications
FOUNDER_EMAIL=founder@example.com
